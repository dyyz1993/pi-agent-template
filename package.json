{
  "name": "pi-agent-template",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "create": "bun run scripts/create.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test": "cd packages/rpc-core && bun test tests/",
    "test:rpc": "cd packages/rpc-core && bun test tests/",
    "test:agent": "cd templates/agent && npx vitest run",
    "test:chat": "cd templates/chat && npx vitest run",
    "test:general": "cd templates/general && npx vitest run",
    "test:templates": "bun run test:agent && bun run test:chat && bun run test:general",
    "test:e2e-ui": "bun run scripts/e2e-ui-test.ts",
    "test:e2e-ui:agent": "bun run scripts/e2e-ui-test.ts agent",
    "test:e2e-ui:chat": "bun run scripts/e2e-ui-test.ts chat",
    "test:e2e-ui:general": "bun run scripts/e2e-ui-test.ts general",
    "test:e2e-ui:all": "bun run test:e2e-ui:general && bun run test:e2e-ui:chat && bun run test:e2e-ui:agent",
    "test:integration:all": "HUSKY=0 bun run scripts/e2e-test.ts --type general && HUSKY=0 bun run scripts/e2e-test.ts --type chat && HUSKY=0 bun run scripts/e2e-test.ts --type agent",
    "test:e2e-ui:headed": "npx playwright test --headed",
    "type-check": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "packages/rpc-core/src/**/*.ts": [
      "eslint --fix"
    ],
    "packages/pi-cli/src/**/*.ts": [
      "eslint --fix",
      "echo 'Note: package is published as @dyyz1993/create-agent'"
    ],
    "scripts/**/*.ts": [
      "eslint --fix"
    ]
  },
  "workspaces": [
    "packages/*",
    "templates/*"
  ]
}
