{
  "name": "pi-agent-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "create": "bun run scripts/create.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test": "cd packages/rpc-core && bun test tests/rpc.test.ts",
    "test:rpc": "cd packages/rpc-core && bun test tests/rpc.test.ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "latest",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "packages/rpc-core/src/**/*.ts": [
      "eslint --fix"
    ],
    "scripts/**/*.ts": [
      "eslint --fix"
    ]
  }
}
