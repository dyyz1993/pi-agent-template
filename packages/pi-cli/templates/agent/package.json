{
	"name": "pi-agent-app",
	"version": "1.0.0",
	"description": "Coding agent template with Bash, Rules, and Todo management",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:web": "bun scripts/dev.ts",
		"dev:server": "bun src/server.ts",
		"build": "vite build",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:mac": "vite build && electrobun build --env=canary",
		"build:win": "vite build && electrobun build --env=canary",
		"build:linux": "vite build && electrobun build --env=canary",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepare": "husky"
	},
	"dependencies": {
		"@dyyz1993/rpc-core": "^1.2.0",
		"@tanstack/react-virtual": "^3.13.24",
		"electrobun": "1.18.1",
		"lucide-react": "^1.9.0",
		"prism-react-renderer": "^2.4.1",
		"react": "^18.3.1",
		"react-diff-viewer-continued": "^4.2.2",
		"i18next": "^24.2.2",
		"i18next-browser-languagedetector": "^8.0.4",
		"react-dom": "^18.3.1",
		"react-i18next": "^15.4.1",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@dyyz1993/eslint-plugin-rpc": "workspace:*",
		"@eslint/js": "^9.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/ws": "^8.18.1",
		"ws": "^8.18.0",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"eslint": "^9.0.0",
		"eslint-plugin-jsx-a11y": "^6.10.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"overrides": {
		"minimatch": "^10.0.1"
	}
}
