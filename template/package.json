{
	"name": "pi-agent-app",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"@dyyz1993/rpc-core": "workspace:*",
		"@tanstack/react-virtual": "^3.13.24",
		"electrobun": "1.13.1",
		"lucide-react": "^1.8.0",
		"prism-react-renderer": "^2.4.1",
		"react": "^18.3.1",
		"react-diff-viewer-continued": "^4.2.2",
		"react-dom": "^18.3.1",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"eslint": "^9.0.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.0.3"
	}
}
