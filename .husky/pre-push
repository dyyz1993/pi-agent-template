echo "⏳ Linting all packages..."
bun run lint || { echo "❌ Lint failed. Fix errors before pushing."; exit 1; }

echo "⏳ Running rpc-core tests..."
bun run test:rpc || { echo "❌ rpc-core tests failed."; exit 1; }

echo "⏳ Running template tests..."
bun run test:templates || { echo "❌ Template tests failed."; exit 1; }

echo "⏳ Checking lockfile..."
pnpm install --frozen-lockfile --dry-run 2>/dev/null || { echo "⚠️  pnpm-lock.yaml may be out of date. Run 'pnpm install' and commit the lockfile."; exit 1; }

echo "✅ Pre-push checks passed. Pushing..."
