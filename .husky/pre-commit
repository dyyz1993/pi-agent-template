npx lint-staged

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.tsx\?$' || true)

if [ "$STAGED_TS" -gt 0 ]; then
  echo "⏳ Type checking core packages..."
  for pkg in packages/*/; do
    if [ -f "$pkg/tsconfig.json" ]; then
      (cd "$pkg" && bunx tsc --noEmit 2>&1) && echo "✅ $pkg" || exit 1
    fi
  done
fi

FORBIDDEN=$(git diff --cached --name-only | grep -E '\.env$|credentials|\.pem$|\.key$' || true)
FORBIDDEN="$FORBIDDEN$(git diff --cached --name-only | grep -E '\.env\.' | grep -vE '\.env\.(example|sample|template|defaults)' || true)"
if [ -n "$FORBIDDEN" ]; then
  echo "❌ Potential secrets detected in staged files:"
  echo "$FORBIDDEN"
  exit 1
fi

echo "✅ Pre-commit checks passed"
