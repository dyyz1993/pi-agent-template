#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Use lint-staged for fast incremental linting (only staged files)
npx lint-staged

# Quick type-check for core packages only
echo "⏳ Type checking core packages..."
for pkg in packages/*/; do
  if [ -f "$pkg/tsconfig.json" ]; then
    (cd "$pkg" && npx tsc --noEmit 2>&1) && echo "✅ $pkg" || exit 1
  fi
done

echo "✅ Pre-commit checks passed"
